# .env.example — copy ke .env dan isi nilai yang sesuai

# Wajib: Groq API key (dari https://console.groq.com)
LLM_API=gsk_xxxxxxxx

# CORS origins (domain frontend yang boleh akses backend)
# Tambah domain Cloudflare Pages setelah deploy frontend
CORS_ORIGINS=http://localhost:5173,https://your-app.pages.dev
