{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"mental-health-api\"}[5m])",
          "legendFormat": "{{method}} {{handler}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "title": "Response Time (latency)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"mental-health-api\"}[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"mental-health-api\"}[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"mental-health-api\"}[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"mental-health-api\",status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"mental-health-api\"}[5m]) * 100",
          "legendFormat": "5xx Error %",
          "refId": "A"
        },
        {
          "expr": "rate(http_requests_total{job=\"mental-health-api\",status=~\"4..\"}[5m]) / rate(http_requests_total{job=\"mental-health-api\"}[5m]) * 100",
          "legendFormat": "4xx Error %",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "color": { "mode": "palette-classic" }, "max": 100 },
        "overrides": []
      }
    },
    {
      "title": "Total Requests by Endpoint",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "http_requests_total{job=\"mental-health-api\"}",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requests In Progress",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "http_requests_in_progress{job=\"mental-health-api\"}",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 10 }] } },
        "overrides": []
      }
    },
    {
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "sum(http_requests_total{job=\"mental-health-api\"})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Avg Response Time",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_sum{job=\"mental-health-api\"}[5m]) / rate(http_request_duration_seconds_count{job=\"mental-health-api\"}[5m])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "Error Count (5xx)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "sum(http_requests_total{job=\"mental-health-api\",status=~\"5..\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } },
        "overrides": []
      }
    },
    {
      "title": "Response Time Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_bucket{job=\"mental-health-api\"}[5m])",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ],
      "options": {
        "calculate": true,
        "yBucketBound": "auto"
      }
    }
  ],
